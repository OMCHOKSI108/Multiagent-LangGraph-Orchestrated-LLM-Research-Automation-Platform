    "axes[0].hist(latencies, bins=20, color='#2E86AB', edgecolor='white', alpha=0.8)\n",
    "axes[0].axvline(np.mean(latencies), color='red', linestyle='--', linewidth=2,\n",
    "                label=f'Mean: {np.mean(latencies):.0f}ms')\n",
    "axes[0].axvline(np.median(latencies), color='green', linestyle='--', linewidth=2,\n",
    "                label=f'Median: {np.median(latencies):.0f}ms')\n",
    "axes[0].set_xlabel('Latency (ms)', fontsize=11)\n",
    "axes[0].set_ylabel('Frequency', fontsize=11)\n",
    "axes[0].set_title('Search Query Latency Distribution', fontsize=12, fontweight='bold')\n",
    "axes[0].legend()\n",
    "\n",
    "# Latency over time (scatter)\n",
    "axes[1].scatter(range(len(latencies)), latencies, c='#A23B72', alpha=0.6, s=30)\n",
    "axes[1].plot(range(len(latencies)), latencies, color='#A23B72', alpha=0.3)\n",
    "axes[1].axhline(np.mean(latencies), color='red', linestyle='--', linewidth=1.5,\n",
    "               label=f'Mean: {np.mean(latencies):.0f}ms')\n",
    "axes[1].set_xlabel('Query Number', fontsize=11)\n",
    "axes[1].set_ylabel('Latency (ms)', fontsize=11)\n",
    "axes[1].set_title('Latency Over Time', fontsize=12, fontweight='bold')\n",
    "axes[1].legend()\n",
    "\n",
    "plt.tight_layout()\n",
    "\n",
    "# Save chart\n",
    "chart_path = OUTPUT_DIR / 'real_latency_distribution.png'\n",
    "plt.savefig(chart_path, dpi=150, bbox_inches='tight', facecolor='white')\n",
    "plt.savefig(ASSETS_DIR / 'real_latency_distribution.png', dpi=150, bbox_inches='tight', facecolor='white')\n",
    "plt.show()\n",
    "\n",
    "print(f'\\nChart saved: {chart_path}')"
   ]
  },
  {
