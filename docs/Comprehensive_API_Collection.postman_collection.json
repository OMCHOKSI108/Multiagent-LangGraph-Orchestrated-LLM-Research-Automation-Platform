      "type": "string"
    },
    {
      "key": "apiKey",
      "value": "YOUR_API_KEY",
      "type": "string"
    },
    {
      "key": "adminKey",
      "value": "OMCHOKSI@108_ADMIN_KEY",
      "type": "string"
    }
