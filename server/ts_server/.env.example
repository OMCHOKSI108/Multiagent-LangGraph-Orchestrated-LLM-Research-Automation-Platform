PORT=4000
JWT_SECRET=change-this-to-a-random-secret
APP_URL=http://localhost:3000

# PostgreSQL – provide your own
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=kuchi_db
POSTGRES_USER=kuchi_user
POSTGRES_PASSWORD=kuchi_password

# Email via Resend – get your API key at https://resend.com
RESEND_API_KEY=re_xxxxx
EMAIL_FROM="Multiagent Research Automation Platform <noreply@yourdomain.com>"

# Logging level (error / warn / info / debug)
LOG_LEVEL=info

# FastAPI AI engine URL
FASTAPI_URL=http://localhost:8000
