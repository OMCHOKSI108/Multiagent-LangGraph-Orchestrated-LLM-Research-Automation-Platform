{
  "info": {
    "name": "Server Boilerplate TypeScript API",
    "description": "Comprehensive API collection for TypeScript server boilerplate with GraphQL and REST endpoints",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string",
      "description": "Base URL for the API"
    },
    {
      "key": "apiPrefix",
      "value": "api",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string",
      "description": "JWT Access Token"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string",
      "description": "JWT Refresh Token"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string",
      "description": "Current user ID"
    }
  ],
  "item": [
    {
      "name": "System Endpoints",
      "item": [
        {
          "name": "Get API Version",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/{{apiPrefix}}/version",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiPrefix}}", "version"]
            },
            "description": "Get API version information"
          }
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/{{apiPrefix}}/v1/auth/health",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiPrefix}}", "v1", "auth", "health"]
            },
            "description": "Health check endpoint"
          }
        }
      ]
    },
    {
      "name": "GraphQL Endpoints",
      "item": [
        {
          "name": "User Authentication",
          "item": [
            {
              "name": "Sign Up",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"query\": \"mutation SignUp($data: SignUpInput!) { signUp(data: $data) { message } }\",\n  \"variables\": {\n    \"data\": {\n      \"email\": \"user@example.com\",\n      \"password\": \"securePassword123\",\n      \"firstName\": \"John\",\n      \"lastName\": \"Doe\",\n      \"timezone\": \"America/New_York\"\n    }\n  }\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/{{apiPrefix}}/graphql",
                  "host": ["{{baseUrl}}"],
                  "path": ["{{apiPrefix}}", "graphql"]
                },
                "description": "Register a new user account"
              }
            },
            {
              "name": "Login User",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"query\": \"mutation LoginUser($data: LoginUserInput!) { loginUser(data: $data) { message data { id email firstName lastName roles } accessToken refreshToken } }\",\n  \"variables\": {\n    \"data\": {\n      \"email\": \"user@example.com\",\n      \"password\": \"securePassword123\"\n    }\n  }\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/{{apiPrefix}}/graphql",
                  "host": ["{{baseUrl}}"],
                  "path": ["{{apiPrefix}}", "graphql"]
                },
                "description": "Login with email and password"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "if (pm.response.code === 200) {",
                      "  const jsonData = pm.response.json();",
                      "  if (jsonData.data && jsonData.data.loginUser) {",
                      "    pm.collectionVariables.set('accessToken', jsonData.data.loginUser.accessToken);",
                      "    pm.collectionVariables.set('refreshToken', jsonData.data.loginUser.refreshToken);",
                      "    pm.collectionVariables.set('userId', jsonData.data.loginUser.data.id);",
                      "  }",
                      "}"
                    ]
                  }
                }
              ]
            },
            {
              "name": "Firebase Login",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"query\": \"mutation FirebaseLogin($data: FirebaseLoginDataInput!) { firebaseLogin(data: $data) { message data { id email firstName lastName roles } accessToken refreshToken } }\",\n  \"variables\": {\n    \"data\": {\n      \"token\": \"firebase_id_token_here\"\n    }\n  }\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/{{apiPrefix}}/graphql",
                  "host": ["{{baseUrl}}"],
                  "path": ["{{apiPrefix}}", "graphql"]
                },
                "description": "Login with Firebase ID token"
              }
            },
            {
              "name": "Get Current User (Me)",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"query\": \"query Me { me { id email firstName lastName profileImage roles lastActiveOn mobileNo createdAt updatedAt unReadCount disabledAt disabledBy address1 address2 city state country zipcode } }\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/{{apiPrefix}}/graphql",
                  "host": ["{{baseUrl}}"],
                  "path": ["{{apiPrefix}}", "graphql"]
                },
                "description": "Get current user information"
              }
            },
            {
              "name": "Refresh Token",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"query\": \"mutation RefreshToken($data: RefreshTokenInput!) { refreshToken(data: $data) { user { id email firstName lastName } accessToken } }\",\n  \"variables\": {\n    \"data\": {\n      \"refreshToken\": \"{{refreshToken}}\"\n    }\n  }\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/{{apiPrefix}}/graphql",
                  "host": ["{{baseUrl}}"],
                  "path": ["{{apiPrefix}}", "graphql"]
                },
                "description": "Refresh access token using refresh token"
              }
            },
            {
              "name": "Logout",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"query\": \"mutation LogoutUser { logoutUser { message } }\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/{{apiPrefix}}/graphql",
                  "host": ["{{baseUrl}}"],
                  "path": ["{{apiPrefix}}", "graphql"]
                },
                "description": "Logout current user"
              }
            }
          ]
        },
