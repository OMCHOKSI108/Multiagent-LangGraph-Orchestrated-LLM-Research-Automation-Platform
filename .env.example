# PostgreSQL
POSTGRES_USER=kuchi_user
POSTGRES_PASSWORD=kuchi_password
POSTGRES_DB=kuchi_db

# LLM provider (groq | openrouter)
DEFAULT_LLM_PROVIDER=groq

# Groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct

# Request settings
LLM_REQUEST_TIMEOUT=60
MAX_CONTEXT_MESSAGES=12

# ── Phase 5: Embeddings ──
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ── Phase 5: Chunking ──
CHUNK_SIZE=900
CHUNK_OVERLAP=150
CHUNK_SIZE_CHARS=4000
CHUNK_OVERLAP_CHARS=500

# ── Phase 5: Retrieval ──
TOP_K_RETRIEVAL=5
MIN_RETRIEVAL_SCORE=0.30
RAG_TOP_K=6
RAG_MIN_SCORE=0.25

# ── Phase 5: Upload ──
MAX_UPLOAD_MB=50
MAX_FILES_PER_UPLOAD=10
UPLOAD_DIR=/app/storage/uploads

# ── Phase 6: Web Research ──

# Search provider (tavily | brave | exa)
WEB_SEARCH_PROVIDER=tavily

# At least one search API key
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
EXA_API_KEY=

# Search settings
WEB_MAX_SEARCH_RESULTS=10
WEB_MAX_SOURCES_TO_CRAWL=5

# Crawl settings
WEB_CRAWL_TIMEOUT=60
WEB_CRAWL_CONCURRENCY=3
WEB_RESPECT_ROBOTS=true
WEB_USER_AGENT=KuchiBot/1.0 (research assistant)

# Domain allow/deny
WEB_ALLOWED_DOMAINS=
WEB_BLOCKED_DOMAINS=facebook.com,twitter.com,instagram.com,tiktok.com,pinterest.com

# RAG over web chunks
WEB_CHUNK_SIZE_CHARS=4000
WEB_CHUNK_OVERLAP_CHARS=500
WEB_RAG_TOP_K=8
WEB_RAG_MIN_SCORE=0.25

# Storage
WEB_STORAGE_DIR=/app/storage/web

# ── Phase 8: Research Draft Writer ─────────────────────────────────────────
DRAFT_MAX_SECTION_WORDS=900
DRAFT_DEFAULT_STYLE=academic
DRAFT_EXPORT_DIR=/app/exports/research_drafts
DRAFT_MIN_CITATION_COVERAGE=0.5
DRAFT_MAX_REVISION_ROUNDS=2

# ── Phase 9: LaTeX / PDF Compilation ─────────────────────────────────────────
LATEX_TEMPLATE_DEFAULT=ieee_conference
LATEX_AUTHOR_NAME=Om Choksi
LATEX_AUTHOR_AFFILIATION=CHARUSAT University
LATEX_AUTHOR_EMAIL=
LATEX_PROJECT_DIR=/app/exports/latex_projects
LATEX_COMPILER=latexmk
LATEX_MAX_REPAIR_ATTEMPTS=2
LATEX_COMPILE_TIMEOUT=120

# ── Phase 10: Voice Mode (Push-to-Talk) ─────────────────────────────────────
VOICE_ENABLED=true
VOICE_STT_PROVIDER=groq
VOICE_TTS_PROVIDER=groq
VOICE_AUDIO_DIR=/app/uploads/audio
VOICE_MAX_AUDIO_MB=15
VOICE_AUTO_SEND_AFTER_TRANSCRIPT=false
VOICE_REPLY_AUDIO_ENABLED=true
VOICE_MAX_TTS_CHARS=4000

# Groq STT/TTS (requires GROQ_API_KEY)
GROQ_STT_MODEL=whisper-large-v3-turbo
GROQ_TTS_MODEL=canopylabs/orpheus-v1-english
GROQ_TTS_VOICE=hannah
GROQ_TTS_RESPONSE_FORMAT=wav

# ── Phase 11: Job Queue (RQ + Redis) ─────────────────────────────────────────
JOB_QUEUE_BACKEND=rq
REDIS_URL=redis://redis:6379/0
JOB_DEFAULT_TIMEOUT=1800
JOB_RESULT_TTL=86400
JOB_FAILURE_TTL=604800
JOB_MAX_RETRIES=2
JOB_ENABLE_SSE=true
JOB_POLL_INTERVAL_SECONDS=3
JOB_QUEUE_INGESTION=ingestion
JOB_QUEUE_WEB=web
JOB_QUEUE_RESEARCH=research
JOB_QUEUE_DRAFT=draft
JOB_QUEUE_LATEX=latex
JOB_QUEUE_VOICE=voice

# ── Phase 12: Scheduler & Recipes ────────────────────────────────────────────
SCHEDULER_ENABLED=true
SCHEDULER_TICK_SECONDS=60
SCHEDULER_TIMEZONE=Asia/Kolkata
SCHEDULER_MIN_INTERVAL_MINUTES=15
SCHEDULER_MAX_CONCURRENT_RECIPE_RUNS=3
SCHEDULER_LOOKAHEAD_MINUTES=5
DIGEST_EXPORT_DIR=/app/exports/digests

# ── Phase 13: Notifications & Delivery Channels ───────────────────────────────
NOTIFICATIONS_ENABLED=true

# Email via SMTP (optional — leave empty to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# Email via Resend (optional — alternative to SMTP)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Telegram bot (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Webhook delivery
WEBHOOK_DELIVERY_TIMEOUT=10

# ── Phase 14: Admin, Security & Settings ─────────────────────────────────────
ADMIN_ENABLED=true
ADMIN_REQUIRE_LOCAL_ONLY=true
# Optional: set a password to protect the Admin panel (blank = local-only open)
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=kuchi-local-admin-secret

SECURITY_RATE_LIMITS_ENABLED=true
SECURITY_AUDIT_LOGS_ENABLED=true
SECURITY_MAX_JSON_MB=5

BACKUP_DIR=/app/exports/backups
BACKUP_INCLUDE_SECRETS=false

CLEANUP_DRY_RUN_DEFAULT=true
CLEANUP_MAX_DELETE_BATCH=1000

# Feature flags — disable a feature to hide it from API and UI
FEATURE_DOCUMENT_RAG=true
FEATURE_WEB_RESEARCH=true
FEATURE_RESEARCH_PROJECTS=true
FEATURE_DRAFT_WRITER=true
FEATURE_LATEX=true
FEATURE_VOICE=true
FEATURE_JOBS=true
FEATURE_SCHEDULER=true
FEATURE_NOTIFICATIONS=true
FEATURE_EXTERNAL_DELIVERY=false

# ── Phase 15: Evaluation Framework ───────────────────────────────────────────
FEATURE_EVALUATION=true
FEATURE_LLM_GRADER=false
EVAL_DEFAULT_MAX_TESTS=50
EVAL_EXPORT_DIR=/app/exports/evaluations
EVAL_FAIL_THRESHOLD=0.70
EVAL_WARNING_THRESHOLD=0.85
EVAL_USE_LLM_GRADER=false
EVAL_LLM_GRADER_MODEL=
EVAL_STORE_FULL_OUTPUTS=true

# ── Phase 16: Demo Mode ──────────────────────────────────────────────────────
# Seeds sample sessions, documents, projects, and digests at startup
DEMO_MODE=false

# ── Docker Compose ───────────────────────────────────────────────────────────
# Host/port wiring — inside Docker, compose overrides POSTGRES_HOST=postgres,
# REDIS_HOST=redis, FASTAPI_URL=http://fastapi:8000 automatically.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
REDIS_HOST=localhost
REDIS_PORT=6379

# Published host ports (change if something else already uses them)
CLIENT_PORT=3000
NODE_PORT=4000
FASTAPI_PORT=8000

# ── Node server (GraphQL auth) ───────────────────────────────────────────────
PORT=4000
JWT_SECRET=change-me-in-production
APP_URL=http://localhost:3000
EMAIL_FROM=Multiagent Research Automation Platform <noreply@deepresearch.app>
LOG_LEVEL=info

# ── Client (baked into browser bundle at build time) ─────────────────────────
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql
NEXT_PUBLIC_API_URL=http://localhost:4000
