   "source": [
    "# Multi-Agent LLM Research Platform\n",
    "## Testing and Evaluation Notebook\n",
    "\n",
    "This notebook contains comprehensive tests and real evaluations for the Multi-Agent LLM Research Automation Platform.\n",
    "\n",
    "**Prerequisites:**\n",
    "- Docker Compose services running (AI Engine + Backend + PostgreSQL + Redis)\n",
    "- Required Python packages: `requests`, `matplotlib`, `numpy`, `seaborn`\n",
    "\n",
    "```bash\n",
    "# Install dependencies\n",
    "pip install requests matplotlib numpy seaborn\n",
    "\n",
    "# Ensure Docker services are running\n",
    "docker-compose up -d\n",
    "```"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Cell 1: Import Dependencies and Setup"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import requests\n",
    "import time\n",
    "import json\n",
    "import random\n",
    "import os\n",
    "from datetime import datetime\n",
    "from pathlib import Path\n",
    "from collections import defaultdict\n",
    "\n",
    "import matplotlib\n",
    "matplotlib.use('Agg')\n",
    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "import seaborn as sns\n",
    "\n",
    "# Setup\n",
    "plt.style.use('seaborn-v0_8-whitegrid')\n",
    "sns.set_palette('husl')\n",
    "\n",
    "# Service URLs (Docker Compose ports)\n",
    "AI_ENGINE_URL = 'http://localhost:8000'\n",
    "BACKEND_URL = 'http://localhost:5001'\n",
    "\n",
    "# Output directories\n",
    "OUTPUT_DIR = Path('../output/evaluation')\n",
    "ASSETS_DIR = Path('../assets/evaluation')\n",
    "OUTPUT_DIR.mkdir(parents=True, exist_ok=True)\n",
    "ASSETS_DIR.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "print('Setup complete!')\n",
    "print(f'AI Engine URL: {AI_ENGINE_URL}')\n",
    "print(f'Backend URL: {BACKEND_URL}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Cell 2: Service Health Check"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def check_services():\n",
    "    \"\"\"Check if AI Engine and Backend are reachable.\"\"\"\n",
    "    results = {}\n",
    "    \n",
    "    # Check AI Engine\n",
    "    try:\n",
    "        resp = requests.get(f'{AI_ENGINE_URL}/health', timeout=5)\n",
    "        results['ai_engine'] = {\n",
    "            'status': 'OK' if resp.status_code == 200 else 'FAILED',\n",
    "            'code': resp.status_code,\n",
    "            'data': resp.json() if resp.status_code == 200 else None\n",
    "        }\n",
    "    except Exception as e:\n",
    "        results['ai_engine'] = {'status': 'ERROR', 'error': str(e)}\n",
    "    \n",
    "    # Check Backend\n",
    "    try:\n",
    "        resp = requests.get(f'{BACKEND_URL}/api/health', timeout=5)\n",
    "        results['backend'] = {\n",
    "            'status': 'OK' if resp.status_code == 200 else 'FAILED',\n",
    "            'code': resp.status_code\n",
    "        }\n",
    "    except Exception as e:\n",
    "        results['backend'] = {'status': 'ERROR', 'error': str(e)}\n",
    "    \n",
    "    return results\n",
    "\n",
    "# Run health check\n",
    "print('=' * 60)\n",
    "print('SERVICE HEALTH CHECK')\n",
    "print('=' * 60)\n",
    "\n",
    "health = check_services()\n",
    "\n",
    "for service, data in health.items():\n",
    "    status = data.get('status', 'UNKNOWN')\n",
    "    print(f'{service.upper()}: {status}')\n",
    "    if status == 'OK':\n",
    "        print(f'  Response Code: {data.get(\"code\")}')\n",
    "    else:\n",
    "        print(f'  Error: {data.get(\"error\", \"Unknown error\")}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Cell 3: Get LLM Provider Status"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def get_llm_status():\n",
    "    \"\"\"Get LLM provider configuration and status from AI Engine.\"\"\"\n",
    "    try:\n",
    "        resp = requests.get(f'{AI_ENGINE_URL}/llm/status', timeout=10)\n",
    "        if resp.status_code == 200:\n",
    "            return resp.json()\n",
    "        return {'error': f'HTTP {resp.status_code}'}\n",
    "    except Exception as e:\n",
    "        return {'error': str(e)}\n",
    "\n",
    "# Get LLM status\n",
    "print('=' * 60)\n",
    "print('LLM PROVIDER STATUS')\n",
    "print('=' * 60)\n",
    "\n",
    "llm_status = get_llm_status()\n",
    "\n",
    "if 'error' not in llm_status:\n",
    "    print(f\"Mode: {llm_status.get('mode', 'unknown')}\")\n",
    "    \n",
    "    provider = llm_status.get('provider', {})\n",
    "    print(f\"Provider: {provider.get('provider', 'unknown')}\")\n",
    "    print(f\"Model: {provider.get('model', 'unknown')}\")\n",
    "    print(f\"Available: {provider.get('available', 'unknown')}\")\n",
    "    \n",
    "    config = llm_status.get('config', {})\n",
    "    print(f\"\\nConfiguration:\")\n",
    "    print(f\"  Reasoning Model: {config.get('model_reasoning')}\")\n",
    "    print(f\"  Writing Model: {config.get('model_writing')}\")\n",
    "    print(f\"  Coding Model: {config.get('model_coding')}\")\n",
    "    print(f\"  Critical Model: {config.get('model_critical')}\")\n",
    "else:\n",
    "    print(f\"Error: {llm_status['error']}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Cell 4: Get Search Provider Status"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def get_providers_status():\n",
    "    \"\"\"Get search provider status.\"\"\"\n",
    "    try:\n",
    "        resp = requests.get(f'{AI_ENGINE_URL}/providers/status', timeout=10)\n",
    "        if resp.status_code == 200:\n",
    "            return resp.json().get('providers', [])\n",
    "        return []\n",
    "    except Exception as e:\n",
    "        print(f'Error: {e}')\n",
    "        return []\n",
    "\n",
    "# Get provider status\n",
    "print('=' * 60)\n",
    "print('SEARCH PROVIDER STATUS')\n",
    "print('=' * 60)\n",
    "\n",
    "providers = get_providers_status()\n",
    "print(f'Total providers: {len(providers)}')\n",
    "\n",
    "for p in providers:\n",
    "    name = p.get('name', 'unknown')\n",
    "    available = 'Yes' if p.get('available') else 'No'\n",
    "    print(f'  - {name}: Available={available}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Cell 5: Run Single Search Query Test"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def run_search_query(query, max_results=10):\n",
    "    \"\"\"Run a single search query through the AI Engine.\"\"\"\n",
    "    result = {\n",
    "        'query': query,\n",
    "        'start_time': time.time(),\n",
    "        'success': False,\n",
    "        'latency_ms': 0,\n",
    "        'results_count': 0,\n",
    "        'sources': [],\n",
    "        'providers_used': [],\n",
    "        'error': None\n",
    "    }\n",
    "\n",
    "    try:\n",
    "        start = time.time()\n",
    "        resp = requests.post(\n",
    "            f'{AI_ENGINE_URL}/search',\n",
    "            json={'query': query, 'max_results': max_results},\n",
    "            timeout=60\n",
    "        )\n",
    "        result['latency_ms'] = (time.time() - start) * 1000\n",
    "\n",
    "        if resp.status_code == 200:\n",
    "            data = resp.json()\n",
    "            result['success'] = True\n",
    "            result['results_count'] = data.get('total_results', 0)\n",
    "            result['sources'] = [r.get('source', 'unknown') for r in data.get('results', [])]\n",
    "            result['providers_used'] = data.get('providers_used', [])\n",
    "            result['results'] = data.get('results', [])\n",
    "        else:\n",
    "            result['error'] = f\"HTTP {resp.status_code}: {resp.text[:100]}\"\n",
    "\n",
    "    except Exception as e:\n",
    "        result['error'] = str(e)\n",
    "\n",
    "    return result\n",
    "\n",
    "# Test single search query\n",
    "print('=' * 60)\n",
    "print('SINGLE SEARCH QUERY TEST')\n",
    "print('=' * 60)\n",
    "\n",
    "test_query = 'machine learning optimization techniques'\n",
    "print(f'Query: {test_query}')\n",
    "\n",
    "result = run_search_query(test_query)\n",
    "\n",
    "print(f\"\\nStatus: {'SUCCESS' if result['success'] else 'FAILED'}\")\n",
    "print(f\"Latency: {result['latency_ms']:.0f} ms\")\n",
    "print(f\"Results Found: {result['results_count']}\")\n",
    "print(f\"Providers Used: {result['providers_used']}\")\n",
    "\n",
    "if result.get('results'):\n",
    "    print(f\"\\nTop 3 Results:\")\n",
    "    for i, r in enumerate(result['results'][:3], 1):\n",
    "        print(f\"  {i}. {r.get('title', 'No title')[:60]}...\")\n",
    "        print(f\"     Source: {r.get('source', 'unknown')}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Cell 6: Run Multiple Search Queries (Batch Test)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Define test topics\n",
    "RESEARCH_TOPICS = [\n",
    "    'machine learning optimization techniques',\n",
    "    'deep learning neural networks',\n",
    "    'natural language processing transformers',\n",
    "    'reinforcement learning algorithms',\n",
    "    'computer vision applications',\n",
    "    'generative AI models',\n",
    "    'quantum computing machine learning',\n",
    "    'AI ethics and bias detection'\n",
    "]\n",
    "\n",
    "def run_batch_search(topics, delay=2):\n",
    "    \"\"\"Run multiple search queries.\"\"\"\n",
    "    results = []\n",
    "    \n",
    "    for i, topic in enumerate(topics, 1):\n",
    "        print(f'[{i}/{len(topics)}] {topic[:40]}... ', end='')\n",
    "        \n",
    "        result = run_search_query(topic)\n",
    "        results.append(result)\n",
    "        \n",
    "        if result['success']:\n",
    "            print(f'OK ({result[\"latency_ms\"]:.0f}ms, {result[\"results_count\"]} results)')\n",
    "        else:\n",
    "            print(f'FAILED - {result[\"error\"]}')\n",
    "        \n",
    "        if i < len(topics):\n",
    "            time.sleep(delay)\n",
    "    \n",
    "    return results\n",
    "\n",
    "# Run batch test\n",
    "print('=' * 60)\n",
    "print('BATCH SEARCH TEST (8 Topics)')\n",
    "print('=' * 60)\n",
    "\n",
    "batch_results = run_batch_search(RESEARCH_TOPICS, delay=1)\n",
    "\n",
    "# Summary\n",
    "successful = sum(1 for r in batch_results if r['success'])\n",
    "avg_latency = np.mean([r['latency_ms'] for r in batch_results if r['success']])\n",
    "total_results = sum(r['results_count'] for r in batch_results if r['success'])\n",
    "\n",
    "print('\\n' + '=' * 60)\n",
    "print('BATCH TEST SUMMARY')\n",
    "print('=' * 60)\n",
    "print(f'Successful: {successful}/{len(batch_results)} ({successful/len(batch_results)*100:.1f}%)')\n",
    "print(f'Avg Latency: {avg_latency:.0f} ms')\n",
    "print(f'Total Results: {total_results}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Cell 7: Collect Real Evaluation Metrics"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class RealMetricsCollector:\n",
    "    \"\"\"Collects real metrics from the running platform.\"\"\"\n",
    "    \n",
    "    def __init__(self, topics):\n",
    "        self.topics = topics\n",
    "        self.search_metrics = []\n",
    "        self.agent_timings = defaultdict(list)\n",
    "        self.errors = []\n",
    "    \n",
    "    def run_search_query(self, query):\n",
    "        \"\"\"Run search query.\"\"\"\n",
    "        result = {\n",
    "            'query': query,\n",
    "            'timestamp': time.time(),\n",
    "            'success': False,\n",
    "            'latency_ms': 0,\n",
    "            'results_count': 0,\n",
    "            'providers': [],\n",
    "            'error': None\n",
    "        }\n",
    "        \n",
    "        try:\n",
    "            start = time.time()\n",
    "            resp = requests.post(\n",
    "                f'{AI_ENGINE_URL}/search',\n",
    "                json={'query': query, 'max_results': 10},\n",
    "                timeout=60\n",
    "            )\n",
    "            result['latency_ms'] = (time.time() - start) * 1000\n",
    "            \n",
    "            if resp.status_code == 200:\n",
    "                data = resp.json()\n",
    "                result['success'] = True\n",
    "                result['results_count'] = data.get('total_results', 0)\n",
    "                result['providers'] = data.get('providers_used', [])\n",
    "            else:\n",
    "                result['error'] = f\"HTTP {resp.status_code}\"\n",
    "                \n",
    "        except Exception as e:\n",
    "            result['error'] = str(e)\n",
    "            self.errors.append({'type': 'search', 'error': str(e)})\n",
    "        \n",
    "        return result\n",
    "    \n",
    "    def test_agent(self, agent_slug, input_data):\n",
    "        \"\"\"Test agent endpoint.\"\"\"\n",
    "        result = {\n",
    "            'agent': agent_slug,\n",
    "            'success': False,\n",
    "            'latency_ms': 0,\n",
    "            'error': None\n",
    "        }\n",
    "        \n",
    "        try:\n",
    "            start = time.time()\n",
    "            resp = requests.post(\n",
    "                f'{AI_ENGINE_URL}/agents/{agent_slug}/test',\n",
    "                json=input_data,\n",
    "                timeout=60\n",
    "            )\n",
    "            result['latency_ms'] = (time.time() - start) * 1000\n",
    "            result['success'] = resp.status_code == 200\n",
    "            if not result['success']:\n",
    "                result['error'] = f\"HTTP {resp.status_code}\"\n",
    "                \n",
    "        except Exception as e:\n",
    "            result['error'] = str(e)\n",
    "        \n",
    "        return result\n",
    "\n",
    "# Initialize collector\n",
    "print('Initializing Real Metrics Collector...')\n",
    "collector = RealMetricsCollector(RESEARCH_TOPICS)\n",
    "print(f'Topics to test: {len(collector.topics)}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Cell 8: Run Evaluation Loop"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Run evaluation (modify NUM_ITERATIONS for longer/shorter tests)\n",
    "NUM_ITERATIONS = 50  # Number of queries to run\n",
    "\n",
    "print('=' * 60)\n",
    "print(f'REAL EVALUATION ({NUM_ITERATIONS} queries)')\n",
    "print('=' * 60)\n",
    "print(f'Started: {datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")}')\n",
    "\n",
    "start_time = time.time()\n",
    "\n",
    "for i in range(NUM_ITERATIONS):\n",
    "    topic = random.choice(collector.topics)\n",
    "    \n",
    "    # Progress indicator\n",
    "    if i % 10 == 0:\n",
    "        print(f'\\nProgress: {i}/{NUM_ITERATIONS} queries completed')\n",
    "    \n",
    "    # Run search\n",
    "    result = collector.run_search_query(topic)\n",
    "    collector.search_metrics.append(result)\n",
    "    \n",
    "    # Small delay between queries\n",
    "    time.sleep(1)\n",
    "\n",
    "end_time = time.time()\n",
    "total_duration = end_time - start_time\n",
    "\n",
    "print(f'\\n' + '=' * 60)\n",
    "print('EVALUATION COMPLETE')\n",
    "print('=' * 60)\n",
    "print(f'Duration: {total_duration:.1f} seconds')\n",
    "print(f'Queries: {len(collector.search_metrics)}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Cell 9: Compute Statistics"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Compute statistics from collected metrics\n",
    "print('=' * 60)\n",
    "print('REAL METRICS STATISTICS')\n",
    "print('=' * 60)\n",
    "\n",
    "successful_queries = [r for r in collector.search_metrics if r['success']]\n",
    "failed_queries = [r for r in collector.search_metrics if not r['success']]\n",
    "\n",
    "# Success metrics\n",
    "success_rate = len(successful_queries) / len(collector.search_metrics) * 100\n",
    "print(f'\\nSuccess Rate: {success_rate:.1f}%')\n",
    "print(f'Successful: {len(successful_queries)}')\n",
    "print(f'Failed: {len(failed_queries)}')\n",
    "\n",
    "# Latency metrics\n",
    "latencies = [r['latency_ms'] for r in successful_queries]\n",
    "print(f'\\nLatency Statistics:')\n",
    "print(f'  Mean: {np.mean(latencies):.0f} ms')\n",
    "print(f'  Median: {np.median(latencies):.0f} ms')\n",
    "print(f'  Std Dev: {np.std(latencies):.0f} ms')\n",
    "print(f'  Min: {np.min(latencies):.0f} ms')\n",
    "print(f'  Max: {np.max(latencies):.0f} ms')\n",
    "\n",
    "# Results count\n",
    "result_counts = [r['results_count'] for r in successful_queries]\n",
    "print(f'\\nResults per Query:')\n",
    "print(f'  Mean: {np.mean(result_counts):.1f}')\n",
    "print(f'  Total: {sum(result_counts)}')\n",
    "\n",
    "# Provider usage\n",
    "provider_counts = defaultdict(int)\n",
    "for r in successful_queries:\n",
    "    for p in r['providers']:\n",
    "        provider_counts[p] += 1\n",
    "\n",
    "print(f'\\nProvider Usage:')\n",
    "for provider, count in sorted(provider_counts.items(), key=lambda x: -x[1]):\n",
    "    print(f'  {provider}: {count} queries ({count/len(successful_queries)*100:.1f}%)')"
   ]
  },
  {
