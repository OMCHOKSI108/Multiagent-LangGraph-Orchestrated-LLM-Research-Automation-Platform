  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-set timestamp for timestamp validation if enabled",
          "if (pm.request.url.path.includes('graphql') || pm.request.url.path.includes('api')) {",
          "  pm.request.headers.add({",
          "    key: 'X-Timestamp',",
          "    value: Date.now().toString()",
          "  });",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-extract tokens from login responses",
          "if (pm.response.code === 200) {",
          "  const jsonData = pm.response.json();",
          "  ",
          "  // Handle GraphQL login response",
          "  if (jsonData.data && jsonData.data.loginUser) {",
          "    if (jsonData.data.loginUser.accessToken) {",
          "      pm.collectionVariables.set('accessToken', jsonData.data.loginUser.accessToken);",
          "    }",
          "    if (jsonData.data.loginUser.refreshToken) {",
          "      pm.collectionVariables.set('refreshToken', jsonData.data.loginUser.refreshToken);",
          "    }",
          "    if (jsonData.data.loginUser.data && jsonData.data.loginUser.data.id) {",
          "      pm.collectionVariables.set('userId', jsonData.data.loginUser.data.id);",
          "    }",
          "  }",
          "  ",
          "  // Handle GraphQL refresh token response",
          "  if (jsonData.data && jsonData.data.refreshToken) {",
          "    if (jsonData.data.refreshToken.accessToken) {",
          "      pm.collectionVariables.set('accessToken', jsonData.data.refreshToken.accessToken);",
          "    }",
          "  }",
          "}"
        ]
      }
    }
  ]
