   "source": [
    "## Cell 11: Generate Results Count Chart"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Generate results count chart\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "# Histogram of results count\n",
    "axes[0].hist(result_counts, bins=10, color='#28A745', edgecolor='white', alpha=0.8)\n",
    "axes[0].axvline(np.mean(result_counts), color='red', linestyle='--', linewidth=2,\n",
