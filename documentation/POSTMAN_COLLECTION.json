                  "raw": "{\n  \"query\": \"mutation UpdateEvent($where: EventUniqueInput!, $data: UpdateEventInput!) { updateEvent(where: $where, data: $data) { message data { id title description eventDate } } }\",\n  \"variables\": {\n    \"where\": {\n      \"id\": \"event_id_here\"\n    },\n    \"data\": {\n      \"title\": \"Updated Team Meeting\",\n      \"description\": \"Updated monthly team sync meeting\",\n      \"eventDate\": \"2023-12-02T10:00:00Z\"\n    }\n  }\n}"
